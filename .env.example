# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your_secret_key_here_minimum_32_characters_long
ADMIN_PIN=1234
BARBER_PHONE=972522682209

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Firebase Web (for client push notifications) ───────────────────────────
FIREBASE_WEB_API_KEY=your_web_api_key
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_WEB_APP_ID=your_web_app_id
FIREBASE_VAPID_KEY=your_vapid_key

# ─── Google Calendar ─────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=your-email@gmail.com
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
RENDER_EXTERNAL_URL=https://your-app.onrender.com
SERVER_URL=https://your-app.onrender.com
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_REVIEW_LINK
